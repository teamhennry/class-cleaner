{
  "entities": {
    "Settings": {
      "title": "Settings",
      "description": "App settings including teacher PIN and student list",
      "type": "object",
      "properties": {
        "teacherPin": {
          "type": "string",
          "description": "4-digit pin for the teacher mode"
        },
        "studentsList": {
          "type": "array",
          "description": "List of all student names in the class"
        }
      },
      "required": ["teacherPin", "studentsList"]
    },
    "CleaningNotice": {
      "title": "CleaningNotice",
      "description": "Notice board message shown to students",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string"
        },
        "author": {
          "type": "string"
        }
      },
      "required": ["id", "content", "updatedAt", "author"]
    },
    "CleaningZone": {
      "title": "CleaningZone",
      "description": "A specific cleaning area in the classroom",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "iconName": {
          "type": "string"
        }
      },
      "required": ["id", "name", "description", "iconName"]
    },
    "WeeklyAssignment": {
      "title": "WeeklyAssignment",
      "description": "Assignment mapping of students to a zone on a weekday",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "zoneId": {
          "type": "string"
        },
        "dayOfWeek": {
          "type": "string"
        },
        "students": {
          "type": "array"
        }
      },
      "required": ["id", "zoneId", "dayOfWeek", "students"]
    },
    "DailyCompletion": {
      "title": "DailyCompletion",
      "description": "Record of a single zone's completion status on a specific date",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "date": {
          "type": "string"
        },
        "zoneId": {
          "type": "string"
        },
        "completed": {
          "type": "boolean"
        },
        "completedBy": {
          "type": "string"
        },
        "completedAt": {
          "type": "string"
        },
        "selfChecklistChecked": {
          "type": "boolean"
        },
        "peerReviewer": {
          "type": "string"
        },
        "satisfactionScore": {
          "type": "number"
        }
      },
      "required": ["id", "date", "zoneId", "completed", "completedBy", "completedAt", "selfChecklistChecked", "peerReviewer", "satisfactionScore"]
    }
  },
  "firestore": {
    "config/settings": {
      "schema": "Settings",
      "description": "Global application configuration settings"
    },
    "notices/current": {
      "schema": "CleaningNotice",
      "description": "The current notice shown on the dashboard"
    },
    "zones/{zoneId}": {
      "schema": "CleaningZone",
      "description": "Cleaning zones created in the system"
    },
    "assignments/{assignmentId}": {
      "schema": "WeeklyAssignment",
      "description": "Assignments of students to zones for specific days"
    },
    "completions/{completionId}": {
      "schema": "DailyCompletion",
      "description": "Log of cleanings completed on specific calendar dates"
    }
  }
}
